# Database
DATABASE_URL=sqlite:///./relationship_analyzer.db

# Public site URL (HTTPS on production)
BASE_URL=https://your-app.example.com

# Telegram bot
BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# Admin auth (never expose to end users)
ADMIN_TOKEN=

# Admin Telegram chat for premium request alerts
ADMIN_CHAT_ID=

# Optional: direct link for users on /payment/pending (e.g. https://t.me/your_admin)
ADMIN_CONTACT_URL=

# Fallback if ADMIN_CONTACT_URL is empty: pre-filled message to @ADMIN_USERNAME
ADMIN_USERNAME=
